---
// Self-contained light "paper" layout for the Atlas. No Tailwind, no shared
// website chrome — just inlined global CSS so each built page stands alone in
// kolu's Code-tab preview.
interface Props {
  title: string;
  description?: string;
}
const { title, description = "kolu's in-repo knowledge base." } = Astro.props;
const fullTitle = title === "Atlas" ? "the kolu Atlas" : `${title} · the kolu Atlas`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --paper: #f6f7f9;
    --surface: #ffffff;
    --ink: #1a1c20;
    --ink-dim: #3f444b;
    --ink-muted: #6b7178;
    --ink-faint: #9aa0a6;
    --rule: #e3e6ea;
    --rule-soft: #eceef1;
    --amber: #b4690e;
    --amber-soft: #f0e2c8;
    --teal: #0b6478;
    --green: #1b7a3a;
    --gold: #8a5200;
    --alert: #b42318;
    --code-bg: #eef1f4;
    --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, ui-serif, serif;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", "Cascadia Code", Menlo, monospace;
  }

  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 17px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--amber); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .wrap { max-width: 46rem; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .mono { font-family: var(--mono); }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }

  /* ── index ────────────────────────────────────────────── */
  .atlas-title {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    font-weight: 600;
    margin: 0.6rem 0 0;
  }
  .atlas-title .accent { color: var(--amber); }
  .lede { color: var(--ink-dim); max-width: 40rem; margin: 1rem 0 0; font-size: 0.95rem; }
  .wrap-index { max-width: 56rem; }

  /* maturity legend */
  .legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 1.1rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    color: var(--ink-muted);
    margin: 0.7rem 0 0;
  }
  .legend-item { display: inline-flex; align-items: center; gap: 0.4em; }
  .legend-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }

  /* ── index MOC tree — compact, one row per note, scales to ~100 ── */
  .moc { list-style: none; margin: 1.5rem 0 0; padding: 0; }
  /* nested children: indent + a guide rule (the hierarchy) */
  .moc-sub {
    list-style: none;
    margin: 0.05rem 0 0.2rem 0.55rem;
    padding-left: 0.8rem;
    border-left: 1px solid var(--rule);
  }
  .row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.22rem 0.45rem;
    border-radius: 6px;
    line-height: 1.3;
  }
  .row:hover { background: var(--surface); text-decoration: none; }
  .row:hover .row-t { color: var(--amber); }
  .row-dot { flex: none; width: 7px; height: 7px; border-radius: 50%; }
  .row-t { color: var(--ink); font-weight: 600; font-size: 0.95rem; white-space: nowrap; flex: none; }
  .row-d {
    color: var(--ink-muted);
    font-size: 0.84rem;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .row-k {
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    flex: none;
  }
  .row-flag {
    font-family: var(--mono);
    font-size: 0.56rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex: none;
  }
  .row-flag.is-status { color: var(--ink-faint); }
  .row-flag.is-draft { color: var(--alert); }
  .m-seedling { background: var(--gold); }
  .m-budding { background: var(--teal); }
  .m-evergreen { background: var(--green); }

  /* ── note header / footer ─────────────────────────────── */
  .backlink {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
  }
  .backlink:hover { color: var(--amber); }
  .note-h1 {
    font-family: var(--serif);
    font-size: clamp(2.1rem, 5vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    font-weight: 600;
    margin: 1.6rem 0 0;
  }
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-top: 1.1rem;
  }
  .meta-sep { color: var(--ink-faint); }
  .note-sub { color: var(--ink-dim); margin-top: 1.1rem; }
  .note-foot {
    display: flex;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--rule);
  }

  /* ── rendered note prose ──────────────────────────────── */
  .prose { color: var(--ink-dim); }
  .prose > :first-child { margin-top: 0; }
  .prose h2 {
    font-family: var(--serif);
    font-size: 1.6rem;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.6rem 0 0.8rem;
  }
  .prose h3 {
    font-family: var(--serif);
    font-size: 1.25rem;
    color: var(--ink);
    font-weight: 600;
    margin: 2rem 0 0.6rem;
  }
  .prose p { margin: 0 0 1.1rem; }
  .prose strong { color: var(--ink); font-weight: 650; }
  .prose em { font-style: italic; }
  .prose ul, .prose ol { margin: 0 0 1.2rem; padding-left: 1.3rem; }
  .prose li { margin: 0.35rem 0; }
  .prose li::marker { color: var(--ink-faint); }
  .prose a { color: var(--amber); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  .prose code {
    font-family: var(--mono);
    font-size: 0.86em;
    background: var(--code-bg);
    border: 1px solid var(--rule);
    border-radius: 5px;
    padding: 0.08em 0.35em;
  }
  .prose pre {
    background: var(--code-bg);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0 0 1.3rem;
  }
  .prose pre code { background: none; border: 0; padding: 0; font-size: 0.82rem; }
  .prose blockquote {
    margin: 1.3rem 0;
    padding: 0.2rem 0 0.2rem 1.1rem;
    border-left: 3px solid var(--amber-soft);
    color: var(--ink-dim);
  }
  .prose blockquote p:last-child { margin-bottom: 0; }
  .prose hr { border: 0; border-top: 1px solid var(--rule); margin: 2.4rem 0; }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 0 0 1.4rem;
    display: block;
    overflow-x: auto;
  }
  .prose th, .prose td { text-align: left; padding: 0.55rem 0.7rem; border: 1px solid var(--rule); vertical-align: top; }
  .prose th {
    background: var(--rule-soft);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 600;
  }
</style>
