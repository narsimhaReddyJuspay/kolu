---
import { getCollection } from "astro:content";
import IndexTree from "../components/IndexTree.astro";
import AtlasLayout from "../layouts/AtlasLayout.astro";
import { buildNoteTree } from "../lib/indexTree";

// Generated MOC tree: notes nest under their `parents` (flat slugs). Drafts are
// hidden from the build but reachable in `astro dev`. A note with no parent is a
// root, so membership stays automatic — nothing falls through unfiled. Links are
// relative (`./<slug>.html`) so the committed pages navigate both in kolu's Code
// tab and externally via htmlpreview.github.io.
const notes = (await getCollection("atlas"))
  .filter((n) => import.meta.env.DEV || !n.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const roots = buildNoteTree(notes);
---

<AtlasLayout
  title="Atlas"
  description="kolu's in-repo Atlas — plans, designs, reviews, and research, as a generated tree."
>
  <div class="wrap wrap-index">
    <p class="eyebrow">the kolu atlas</p>
    <h1 class="atlas-title">The <span class="accent">Atlas</span>.</h1>
    <p class="lede">
      kolu's in-repo knowledge base — a tree generated from each note's
      <code>parents</code> frontmatter; nothing falls through unfiled.
      <strong>{notes.length}</strong> notes.
    </p>
    <div class="legend">
      <span class="legend-item"><span class="legend-dot m-seedling" />seedling</span>
      <span class="legend-item"><span class="legend-dot m-budding" />budding</span>
      <span class="legend-item"><span class="legend-dot m-evergreen" />evergreen</span>
    </div>

    {
      roots.length > 0 ? (
        <IndexTree nodes={roots} />
      ) : (
        <p class="mono" style="color:var(--ink-muted);padding:3rem 0;text-align:center">
          // the Atlas is empty
        </p>
      )
    }
  </div>
</AtlasLayout>
