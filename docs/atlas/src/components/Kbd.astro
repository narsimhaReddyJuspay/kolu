---
// A keyboard chord — kolu is keybinding-heavy. e.g. <Kbd keys="Ctrl+B" />
interface Props {
  keys: string;
}
const { keys } = Astro.props;
const parts = keys
  .split("+")
  .map((k) => k.trim())
  .filter(Boolean);
---
<span class="kbd-chord">
  {parts.map((k, i) => (
    <Fragment>
      {i > 0 && <span class="kbd-plus">+</span>}
      <kbd class="kbd">{k}</kbd>
    </Fragment>
  ))}
</span>
<style>
  .kbd-chord { display: inline-flex; align-items: center; gap: 0.25em; vertical-align: baseline; }
  .kbd {
    font-family: var(--mono);
    font-size: 0.8em;
    line-height: 1;
    padding: 0.2em 0.45em;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--rule);
    border-bottom-width: 2px;
    border-radius: 5px;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }
  .kbd-plus { color: var(--ink-faint); font-size: 0.75em; }
</style>
