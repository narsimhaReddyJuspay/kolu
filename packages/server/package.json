{
  "name": "kolu-server",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "KOLU_STATE_DIR=\"$(git rev-parse --show-toplevel)/.kolu-dev\" node --watch --import tsx src/index.ts --allow-nix-shell-with-env-whitelist default",
    "typecheck": "tsc --noEmit",
    "test:unit": "KOLU_STATE_DIR=\"${TMPDIR:-/tmp}/kolu-unit-test-$$/state\" vitest run --fileParallelism=false"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.1.0",
    "@kolu/artifact-sdk": "workspace:*",
    "kaval": "workspace:*",
    "@kolu/serve-dir": "workspace:*",
    "@kolu/surface": "workspace:*",
    "@kolu/surface-app": "workspace:*",
    "@kolu/terminal-protocol": "workspace:*",
    "@orpc/client": "^1.13.13",
    "@orpc/contract": "^1.13.13",
    "@orpc/experimental-pino": "^1.13.13",
    "@orpc/experimental-publisher": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "anyagent": "workspace:*",
    "anyforge": "workspace:*",
    "cleye": "^2.3.0",
    "conf": "^15.1.0",
    "hono": "^4.12.21",
    "hono-pino": "^0.10.3",
    "kolu-claude-code": "workspace:*",
    "kolu-codex": "workspace:*",
    "kolu-common": "workspace:*",
    "kolu-git": "workspace:*",
