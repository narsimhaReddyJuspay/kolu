    "pino-pretty": "^13.1.3",
    "selfsigned": "^5.5.0",
    "ts-pattern": "^5.9.0",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
