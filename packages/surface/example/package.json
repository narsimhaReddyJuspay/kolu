{
  "name": "@kolu/surface-example",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx --watch src/server/main.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/server/main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.1.0",
    "@kolu/surface": "workspace:*",
    "@orpc/client": "^1.13.13",
    "@orpc/contract": "^1.13.13",
    "@orpc/experimental-publisher": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "hono": "^4.12.21",
    "partysocket": "^1.1.16",
    "solid-js": "^1.9.0",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.0"
  }
}
